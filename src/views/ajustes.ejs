<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Ajustes' %> - SchoolNode</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <%- include('partials/sidebar') %>

      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <%- include('partials/header') %>

        <h2 class="mb-4">Ajustes del Sistema</h2>

        <div class="row">
          <!-- Configuración General -->
          <div class="col-md-6">
            <div class="card mb-4">
              <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Configuración General</h5>
              </div>
              <div class="card-body">
                <form id="formConfigGeneral">
                  <div class="mb-3">
                    <label class="form-label">Nombre de la Institución</label>
                    <input type="text" class="form-control" id="cfgNombre" required>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Ubicación</label>
                    <input type="text" class="form-control" id="cfgUbicacion" required>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">NIT</label>
                    <input type="text" class="form-control" id="cfgNit">
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Teléfono</label>
                    <input type="text" class="form-control" id="cfgTelefono">
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" id="cfgEmail">
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Color Primario</label>
                    <input type="color" class="form-control form-control-color" id="cfgColor" value="#0d6efd">
                  </div>
                  <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                </form>
              </div>
            </div>
          </div>

          <!-- Configuración de Facturación -->
          <div class="col-md-6">
            <div class="card mb-4">
              <div class="card-header bg-success text-white">
                <h5 class="mb-0">Configuración de Facturación</h5>
              </div>
              <div class="card-body">
                <form id="formConfigFacturacion">
                  <div class="mb-3">
                    <label class="form-label">Prefijo de Factura</label>
                    <input type="text" class="form-control" id="cfgPrefijo" required>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Régimen</label>
                    <select class="form-select" id="cfgRegimen">
                      <option value="Simplificado">Simplificado</option>
                      <option value="Común">Común</option>
                      <option value="Especial">Especial</option>
                    </select>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Resolución DIAN</label>
                    <input type="text" class="form-control" id="cfgResolucion">
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Pie de Factura</label>
                    <textarea class="form-control" id="cfgPieFactura" rows="2"></textarea>
                  </div>
                  <button type="submit" class="btn btn-success">Guardar Configuración</button>
                </form>
              </div>
            </div>
          </div>

          <!-- Credenciales del Admin -->
          <div class="col-md-6">
            <div class="card mb-4">
              <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Credenciales de Administrador</h5>
              </div>
              <div class="card-body">
                <div class="alert alert-info">
                  <strong>Importante:</strong> Cambia las credenciales predeterminadas antes de producción.
                </div>
                <form id="formCredenciales">
                  <div class="mb-3">
                    <label class="form-label">Email Actual</label>
                    <input type="email" class="form-control" id="adminEmailActual" readonly>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Nuevo Email (opcional)</label>
                    <input type="email" class="form-control" id="adminNuevoEmail">
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Nueva Contraseña (opcional)</label>
                    <input type="password" class="form-control" id="adminNuevaPassword" minlength="8" placeholder="Mínimo 8 caracteres">
                  </div>
                  <button type="submit" class="btn btn-warning">Cambiar Credenciales</button>
                </form>
              </div>
            </div>
          </div>

          <!-- Información del Sistema -->
          <div class="col-md-6">
            <div class="card mb-4">
              <div class="card-header bg-info text-white">
                <h5 class="mb-0">Información del Sistema</h5>
              </div>
              <div class="card-body">
                <ul class="list-unstyled">
                  <li class="mb-2"><strong>Versión:</strong> 1.0.0</li>
                  <li class="mb-2"><strong>Entorno:</strong> <%= typeof NODE_ENV !== 'undefined' ? NODE_ENV : 'development' %></li>
                  <li class="mb-2"><strong>Base de datos:</strong> MongoDB Atlas</li>
                  <li class="mb-2"><strong>Node.js:</strong> <%= process.version %></li>
                  <li class="mb-2"><strong>Última actualización:</strong> <span id="ultimaActualizacion">-</span></li>
                </ul>
                <hr>
                <h6>Estadísticas Rápidas</h6>
                <ul class="list-unstyled">
                  <li>Estudiantes: <span id="statEstudiantes">-</span></li>
                  <li>Cursos: <span id="statCursos">-</span></li>
                  <li>Aulas: <span id="statAulas">-</span></li>
                  <li>Matrículas: <span id="statMatriculas">-</span></li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/ajustes.js"></script>
</body>
</html>
