<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Cursos' %> - SchoolNode</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <%- include('../partials/sidebar') %>

      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <%- include('../partials/header') %>

        <h2 class="mb-4">Gestión de Cursos y Aulas</h2>

        <% if (typeof esAdmin !== 'undefined' && esAdmin === true) { %>
        <div class="d-flex gap-2 mb-3">
          <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalNuevaAula">
            Agregar Nueva Aula
          </button>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevoCurso">
            Agregar Nuevo Curso
          </button>
        </div>
        <% } else { %>
        <div class="alert alert-info mb-3">
          <strong>Modo lectura:</strong> Solo los administradores pueden crear, editar o eliminar cursos y aulas.
        </div>
        <% } %>

        <!-- Stats Cards -->
        <div class="row mb-4">
          <div class="col-md-3">
            <div class="card text-bg-info">
              <div class="card-body text-center">
                <h6 class="card-title">Total Cursos</h6>
                <h2 class="mb-0" id="totalCursos">0</h2>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-bg-success">
              <div class="card-body text-center">
                <h6 class="card-title">Total Aulas</h6>
                <h2 class="mb-0" id="totalAulas">0</h2>
              </div>
            </div>
          </div>
        </div>

        <!-- Tabla de Cursos -->
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Cursos Disponibles</h5>
          </div>
          <div class="card-body">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Nombre</th>
                  <th>Duración</th>
                  <th>Precio</th>
                  <th>Aulas Asignadas</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="tablaCursos"></tbody>
            </table>
          </div>
        </div>

        <!-- Tabla de Aulas -->
        <div class="card mt-4">
          <div class="card-header">
            <h5 class="mb-0">Aulas Disponibles</h5>
          </div>
          <div class="card-body">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Número</th>
                  <th>Capacidad</th>
                  <th>Población Actual</th>
                  <th>Ubicación</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="tablaAulas"></tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </div>

  <!-- Modal Nueva Aula -->
  <div class="modal fade" id="modalNuevaAula" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Crear Nueva Aula</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="formNuevaAula">
            <div class="mb-3">
              <label class="form-label">Número de Aula *</label>
              <input type="text" class="form-control" id="aulaNumero" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Capacidad *</label>
              <input type="number" class="form-control" id="aulaCapacidad" min="1" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Ubicación</label>
              <input type="text" class="form-control" id="aulaUbicacion">
            </div>
            <div class="mb-3">
              <label class="form-label">Asociar a Curso</label>
              <select class="form-select" id="aulaCurso">
                <option value="">Ninguno (crear aula independiente)</option>
              </select>
            </div>
            <button type="submit" class="btn btn-success">Crear Aula</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Nuevo Curso -->
  <div class="modal fade" id="modalNuevoCurso" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Crear Nuevo Curso</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="formNuevoCurso">
            <div class="mb-3">
              <label class="form-label">Nombre del Curso *</label>
              <input type="text" class="form-control" id="cursoNombre" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Descripción</label>
              <textarea class="form-control" id="cursoDescripcion" rows="3"></textarea>
            </div>
            <div class="mb-3">
              <label class="form-label">Duración *</label>
              <input type="text" class="form-control" id="cursoDuracion" placeholder="Ej: 4 semanas" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Precio (COP) *</label>
              <input type="number" class="form-control" id="cursoPrecio" min="0" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Asignar Aula (opcional)</label>
              <select class="form-select" id="cursoAula">
                <option value="">Sin aula asignada</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary">Crear Curso</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/cursos.js"></script>
  <script src="/js/usuario.js"></script>
</body>
</html>
