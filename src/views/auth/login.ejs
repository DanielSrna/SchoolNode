<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Iniciar Sesión' %> - SchoolNode</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="bg-light">
  <div class="container">
    <div class="row justify-content-center align-items-center min-vh-100">
      <div class="col-md-4">
        <div class="card shadow">
          <div class="card-body p-4">
            <div class="text-center mb-4">
              <img src="/images/logo-placeholder.png" alt="Logo" class="img-fluid mb-3" style="max-height: 100px;">
              <h3 class="card-title">SchoolNode</h3>
              <p class="text-muted">Iniciar Sesión</p>
            </div>
            
            <form id="loginForm">
              <div class="mb-3">
                <label for="email" class="form-label">Correo Electrónico</label>
                <input type="email" class="form-control" id="email" name="email" required>
              </div>
              
              <div class="mb-3">
                <label for="password" class="form-label">Contraseña</label>
                <input type="password" class="form-control" id="password" name="password" required>
              </div>
              
              <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">
                  Acceder
                </button>
              </div>
            </form>
            
            <div class="text-center mt-3">
              <a href="#" class="text-muted small">¿Olvidó su contraseña?</a>
            </div>
          </div>
        </div>
        
        <div class="text-center mt-3">
          <small class="text-muted">SchoolNode v1.0 - Prototipo TRL5</small>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/login.js"></script>
</body>
</html>
