<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Dashboard' %> - SchoolNode</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <%- include('partials/sidebar') %>

      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <%- include('partials/header') %>

        <h2 class="mb-4">Gestión general del sistema</h2>

        <!-- Stats Cards -->
        <div class="row mb-4">
          <div class="col-md-3">
            <div class="card text-bg-primary">
              <div class="card-body">
                <h5 class="card-title">Estudiantes</h5>
                <p class="card-text display-6" id="totalEstudiantes">-</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-bg-success">
              <div class="card-body">
                <h5 class="card-title">Matrículas Activas</h5>
                <p class="card-text display-6" id="matriculasActivas">-</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-bg-warning">
              <div class="card-body">
                <h5 class="card-title">Ingresos Totales</h5>
                <p class="card-text display-6" id="ingresosTotales">-</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-bg-danger">
              <div class="card-body">
                <h5 class="card-title">Morosos</h5>
                <p class="card-text display-6" id="totalMorosos">-</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Activity -->
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Resumen del Sistema</h5>
          </div>
          <div class="card-body">
            <p>Bienvenido al sistema de gestión escolar SchoolNode.</p>
            <p>Este es un prototipo funcional TRL5 que demuestra:</p>
            <ul>
              <li>Gestión completa de estudiantes, cursos, aulas y matrículas</li>
              <li>Sistema de autenticación con JWT y roles</li>
              <li>Integración con pasarela de pagos Stripe</li>
              <li>Control de capacidad de aulas</li>
              <li>Semaforización de matrículas por vencimiento</li>
            </ul>
            
            <div class="alert alert-info mt-4">
              <strong>Credenciales de prueba:</strong><br>
              Admin: admin@schoolnode.com / Admin123!<br>
              Empleado: empleado1@schoolnode.com / Empleado123!
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/dashboard.js"></script>
  <script src="/js/usuario.js"></script>
</body>
</html>
